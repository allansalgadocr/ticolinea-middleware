# Per-provider secrets for AUTH_METHOD=password. Copy to <slug>.env (matching the
# PROVIDER slug in deploy/providers/<slug>.conf). This file is per-provider and
# gitignored — never commit a real <slug>.env.
#
# Only needed when the provider's .conf sets AUTH_METHOD=password. If either is
# left blank, tico prompts for it interactively (SUDO_PASSWORD defaults to
# SSH_PASSWORD when unset).

# Password for the SSH login (SSH_USER@SSH_HOST).
SSH_PASSWORD=
# Password sudo asks for on the box. Defaults to SSH_PASSWORD when left blank.
SUDO_PASSWORD=
