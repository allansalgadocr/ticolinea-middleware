# Per-provider secrets for AUTH_METHOD=password. Copy to <slug>.env (matching the
# PROVIDER slug in deploy/providers/<slug>.conf). This file is per-provider and
# gitignored — never commit a real <slug>.env.
#
# Only needed when the provider's .conf sets AUTH_METHOD=password. If either is
# left blank, tico prompts for it interactively (SUDO_PASSWORD defaults to
# SSH_PASSWORD when unset).

# Password for the SSH login (SSH_USER@SSH_HOST).
SSH_PASSWORD=
# Password sudo asks for on the box. Defaults to SSH_PASSWORD when left blank.
SUDO_PASSWORD=

# Node console (/admin) bootstrap login for the 'admin' account.
# Leave BLANK to have bootstrap generate a strong one and print it once at the
# end of the run (it is also written to /opt/<slug>/secrets/console-admin-password).
# Set it to hand the owner a password you choose.
#
# Rules — enforced by bootstrap, which refuses to run otherwise:
#   - at least 12 characters
#   - letters, digits, dot, underscore or hyphen ONLY
#     (quotes, spaces and backslashes would break the remote shell quoting and
#      the generated JSON config)
#
# Only takes effect on a node whose console has never been initialised: the node
# seeds the admin account only while node_admin_users is empty, so re-running
# bootstrap never resets a password the owner has already changed.
CONSOLE_SEED_PASSWORD=
