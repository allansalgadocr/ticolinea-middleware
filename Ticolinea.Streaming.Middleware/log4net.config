<log4net>
    <appender name="RollingFile" type="log4net.Appender.RollingFileAppender">
        <!-- LogDir is set from Logging:Directory (default /home/ticolineaplay/logs) in
             Log4netExtensions before Configure; PatternString is required for %property. -->
        <file type="log4net.Util.PatternString" value="%property{LogDir}/TL." />
        <datePattern value="yyyyMMdd'.log'" />
        <staticLogFileName value="false" />
        <appendToFile value="true" />
        <!-- Composite = keep the daily files, but also roll on size so a single noisy day
             cannot fill the disk (cap ~ 50MB * (14 backups + 1 active) per day). -->
        <rollingStyle value="Composite" />
        <maximumFileSize value="50MB" />
        <maxSizeRollBackups value="14" />
        <lockingModel type="log4net.Appender.FileAppender+MinimalLock" />
        <layout type="log4net.Layout.PatternLayout">
            <conversionPattern value="%date [%thread] %-5level %logger - %message%newline" />
        </layout>
    </appender>

    <root>
        <level value="INFO" />
        <appender-ref ref="RollingFile" />
    </root>
</log4net>
